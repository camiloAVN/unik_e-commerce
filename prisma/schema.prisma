generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
}

enum QuoteStatus {
  borrador
  enviada
  aceptada
  rechazada
}

model AppSettings {
  id         String @id @default("singleton")
  adminEmail String @default("")

  // Datos del emisor para las cotizaciones (PDF)
  quoteIssuerName    String @default("UNIK S.A.S.")
  quoteIssuerNit     String @default("")
  quoteIssuerEmail   String @default("")
  quoteIssuerPhone   String @default("")
  quoteIssuerAddress String @default("")
  quoteIssuerWebsite String @default("")

  // Apariencia del PDF de cotización
  quoteFontFamily  String @default("Helvetica") // Helvetica | Times-Roman | Courier
  quoteFontSize    Int    @default(9)
  quoteHeaderColor String @default("#D61C1C")
}

// Imágenes de la galería del hero (slideshow de la home), gestionadas desde Configuración
model HeroImage {
  id        String   @id @default(uuid())
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isActive, sortOrder])
}

// Empresas / clientes B2B con los que se trabaja directamente (fuera del e-commerce)
model Company {
  id          String  @id @default(uuid())
  name        String // Razón social / nombre
  nit         String?
  email       String?
  phone       String?
  contactName String? // Persona de contacto
  address     String?
  city        String?
  notes       String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quotes Quote[]
}

// Cotizaciones asociadas a una empresa/cliente
model Quote {
  id        String      @id @default(uuid())
  number    Int         @unique // consecutivo legible: COT-0001
  status    QuoteStatus @default(borrador)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  issueDate  DateTime  @default(now())
  validUntil DateTime?

  // Snapshot de cálculos al momento de crear/editar
  discountPct    Float @default(0) // porcentaje de descuento
  subTotal       Float @default(0) // suma de líneas (antes de descuento)
  discountAmount Float @default(0)
  taxableBase    Float @default(0) // subTotal - descuento
  tax            Float @default(0) // IVA 19%
  total          Float @default(0)

  notes String? // observaciones
  terms String? // condiciones / términos

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items QuoteItem[]

  @@index([companyId])
}

model QuoteItem {
  id          String  @id @default(uuid())
  description String // título/descripción de la línea (producto o item abierto)
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  total       Float   @default(0) // quantity * unitPrice (snapshot)
  productId   String? // referencia opcional a un Product registrado (sin FK, para conservar historial)
  sortOrder   Int     @default(0)

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  isFeatured  Boolean   @default(false)
  sortOrder   Int       @default(0)
  products    Product[]
}

// Admin-defined variant types: "Talla", "Color", "Material", etc.
model VariantType {
  id     String         @id @default(uuid())
  name   String         @unique
  values VariantValue[]
}

// Possible values for each type: "S", "M", "Rojo", "Algodón", etc.
model VariantValue {
  id            String                @id @default(uuid())
  value         String
  variantTypeId String
  variantType   VariantType           @relation(fields: [variantTypeId], references: [id])
  variantValues ProductVariantValue[]

  @@unique([variantTypeId, value])
}

model Product {
  id          String   @id @default(uuid())
  title       String
  description String
  inStock     Int
  price       Float    @default(0)
  slug        String   @unique
  tags        String[] @default([])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images     ProductImage[]
  orderItems OrderItem[]
  variants   ProductVariant[]

  @@index([categoryId])
}

// A specific variant combination for a product (e.g. Red + Size M)
model ProductVariant {
  id      String  @id @default(uuid())
  price   Float?
  inStock Int     @default(0)
  sku     String? @unique

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  values     ProductVariantValue[]
  orderItems OrderItem[]
}

model ProductVariantValue {
  productVariantId String
  variantValueId   String

  productVariant ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  variantValue   VariantValue   @relation(fields: [variantValueId], references: [id])

  @@id([productVariantId, variantValueId])
}

model ProductImage {
  id        Int    @id @default(autoincrement())
  url       String

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  role          Role      @default(user)
  image         String?
  isActive      Boolean   @default(true)
  cargo         String?
  createdAt     DateTime  @default(now())

  address UserAddress?
  orders  Order[]
}

model Country {
  id             String         @id
  name           String
  userAddresses  UserAddress[]
  orderAddresses OrderAddress[]
}

model UserAddress {
  id         String  @id @default(uuid())
  firstName  String
  lastName   String
  address    String
  address2   String?
  postalCode String
  phone      String
  city       String

  countryId String
  country   Country @relation(fields: [countryId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

model Order {
  id            String    @id @default(uuid())
  subTotal      Float
  tax           Float
  total         Float
  itemsInOrder  Int
  isPaid        Boolean   @default(false)
  paidAt        DateTime?
  isDelivered   Boolean   @default(false)
  deliveredAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  transactionId String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  orderItems   OrderItem[]
  orderAddress OrderAddress?
}

model OrderItem {
  id           String  @id @default(uuid())
  quantity     Int
  price        Float
  variantLabel String? // human-readable, e.g. "Talla: M / Color: Rojo"

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
}

model OrderAddress {
  id         String  @id @default(uuid())
  firstName  String
  lastName   String
  address    String
  address2   String?
  postalCode String
  city       String
  phone      String

  countryId String
  country   Country @relation(fields: [countryId], references: [id])

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])
}
